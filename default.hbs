<!DOCTYPE html>
<html lang="pl" class="{{html_class}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>

    {{!-- Preconnect do Google Fonts --}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {{!-- CSS skompilowany przez Rollup (assets/css/screen.css → assets/built/screen.css) --}}
    <link rel="stylesheet" type="text/css" href="{{asset "built/index.css"}}">

    {{!-- Ghost head: SEO meta, OG, structured data, members scripts - MUSI być ostatnie w <head> --}}
    {{ghost_head}}
</head>
<body class="{{body_class}}">

    {{!-- Nagłówek / nawigacja --}}
    {{> "site-header"}}

    {{!-- Główna treść strony pochodzi z szablonu potomnego --}}
    {{{body}}}

    {{!-- Stopka --}}
    {{> "site-footer"}}

    {{!-- JS skompilowany przez Rollup --}}
    <script src="{{asset "built/index.js"}}"></script>

    {{!-- Ghost foot: members portal, search, komentarze itp. - MUSI być ostatnie w <body> --}}
    {{ghost_foot}}

</body>
</html>

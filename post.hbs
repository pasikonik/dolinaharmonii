{{!< default}}

{{!--
    post.hbs — szablon pojedynczego postu / warsztatu
    URL warsztatu: /warsztaty/{slug}/
    URL posta blogowego: /blog/{slug}/

    Wykrywamy czy to warsztat przez tag #warsztat
    i pokazujemy dodatkowe elementy (sidebar z CTA, termin).

    Pola Ghost używane przez warsztat:
    - title               → nazwa warsztatu
    - feature_image       → główne zdjęcie
    - custom_excerpt      → krótki opis (pokazywany w intro)
    - published_at        → data (użyj jako "termin" lub data publikacji)
    - tags                → kategoria warsztatu (np. mindfulness, medytacja)
    - treść postu         → pełny opis warsztatu, program, co wziąć
--}}

{{#post}}

<main class="post-page">

    {{!-- Hero postu --}}
    <header class="post-hero">
        {{#if feature_image}}
            <div class="post-hero-img">
                <img src="{{feature_image}}" alt="{{title}}">
            </div>
        {{/if}}

        <div class="container">
            <div class="post-hero-content">

                {{!-- Tagi / kategoria --}}
                <div class="post-tags">
                    {{!-- primary_tag pomija automatycznie tagi wewnętrzne (#warsztat) --}}
                    {{#primary_tag}}
                        <span class="chip">{{name}}</span>
                    {{/primary_tag}}
                </div>

                <h1 class="post-title">{{title}}</h1>

                {{#if custom_excerpt}}
                    <p class="post-excerpt">{{custom_excerpt}}</p>
                {{/if}}

                {{!-- Meta: data, czas czytania --}}
                <div class="post-meta-row">
                    <span>{{date published_at format="D MMMM YYYY"}}</span>
                    {{#if reading_time}}
                        <span>·</span>
                        <span>{{reading_time}} min czytania</span>
                    {{/if}}
                </div>

            </div>
        </div>
    </header>

    {{!-- Treść + sidebar --}}
    <div class="container">
        <div class="post-layout">

            {{!-- Główna treść --}}
            <article class="post-content gh-content">
                {{content}}
            </article>

            {{!-- Sidebar: pokazuj tylko dla warsztatów --}}
            {{#has tag="hash-warsztat"}}
                <aside class="post-sidebar">

                    <div class="sidebar-card">
                        <span class="eyebrow" style="display: block; margin-bottom: 16px;">Zarezerwuj miejsce</span>
                        <h3 style="font-size: 22px; margin-bottom: 8px;">{{title}}</h3>

                        {{!-- Termin --}}
                        <div class="sidebar-meta">
                            <div class="sidebar-meta-row">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                <span>{{date published_at format="D MMMM YYYY"}}</span>
                            </div>
                            <div class="sidebar-meta-row">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                <span>{{reading_time}} min · szczegółowy opis</span>
                            </div>
                            <div class="sidebar-meta-row">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                <span>Kopaniec, Góry Izerskie</span>
                            </div>
                        </div>

                        <a class="btn btn-primary" href="mailto:dolina@harmonii.pl?subject=Rezerwacja: {{title}}" style="width: 100%; justify-content: center; margin-bottom: 12px;">
                            Zapytaj o miejsce
                        </a>
                        <a class="btn btn-secondary" href="{{@site.url}}/#newsletter" style="width: 100%; justify-content: center;">
                            Powiadom mnie o terminie
                        </a>

                        <p style="font-size: 12px; color: var(--text-muted); margin-top: 16px; text-align: center;">
                            Odpowiadamy w ciągu 48 godzin
                        </p>
                    </div>

                    {{!-- Inne warsztaty --}}
                    <div class="sidebar-more">
                        <span class="eyebrow" style="display: block; margin-bottom: 20px;">Inne warsztaty</span>
                        {{#get "posts" filter="tag:hash-warsztat+id:-{{id}}" limit="3"}}
                            {{#foreach posts}}
                                <a href="{{url}}" class="sidebar-post">
                                    {{#if feature_image}}
                                        <img src="{{feature_image}}" alt="{{title}}">
                                    {{/if}}
                                    <div>
                                        <p style="font-weight: 600; color: var(--brand-primary); font-size: 14px; margin-bottom: 4px;">{{title}}</p>
                                        <span style="font-size: 12px; color: var(--text-muted);">{{date published_at format="MMM YYYY"}}</span>
                                    </div>
                                </a>
                            {{/foreach}}
                        {{/get}}
                    </div>

                </aside>
            {{/has}}

        </div>{{!-- /.post-layout --}}
    </div>

    {{!-- Komentarze Ghost (opcjonalne — włącz w Admin → Settings → Comments) --}}
    {{#if comments}}
        <div class="container" style="margin-top: 64px;">
            {{comments}}
        </div>
    {{/if}}

</main>

{{/post}}
